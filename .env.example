# Copier ce fichier vers .env et remplir vos clés :
#   copy .env.example .env

# API Groq — rapport d'audit IA (Llama-3.3-70b)
GROQ_API_KEY=votre_cle_groq_ici

# Token du bot Telegram (@BotFather) — requis pour le workflow n8n
# À exporter aussi dans le shell avant de lancer n8n :
#   $env:TELEGRAM_BOT_TOKEN = "votre_token"
TELEGRAM_BOT_TOKEN=votre_token_telegram_ici
